# Copy to `.env` and fill in. NEVER commit the real .env.

# Discord bot token (from https://discord.com/developers/applications).
DISCORD_TOKEN=your-discord-bot-token

# Channel id where proactive alerts are posted (enable Developer Mode in
# Discord, right-click the channel -> Copy Channel ID).
ALERT_CHANNEL_ID=123456789012345678

# The shared backend the dashboard also uses (one source of truth).
BACKEND_URL=http://localhost:8000

# Gemini (used to phrase friendly replies; the bot still works without it).
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# How often (seconds) the bot checks the backend for new alerts to announce.
ALERT_POLL_SECONDS=30
